{
  "name": "hntrip-app",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "install:ci": "bash scripts/install-ci.sh",
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vite",
    "build": "bash scripts/build-verified.sh",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "npm run build && node --test tests/*.test.mjs",
    "validate:artifact": "bash scripts/validate-artifact.sh",
    "lint": "bash scripts/sites-env.sh -- eslint . --ignore-pattern dist --ignore-pattern .next",
    "typecheck": "bash scripts/sites-env.sh -- tsc --project tsconfig.app.json --noEmit",
    "quality": "npm run lint && npm run typecheck && npm run test",
    "db:generate": "bash scripts/sites-env.sh -- drizzle-kit generate",
    "supabase:start": "bash scripts/sites-env.sh -- supabase start",
    "supabase:reset": "bash scripts/sites-env.sh -- supabase db reset",
    "supabase:lint": "bash scripts/sites-env.sh -- supabase db lint --level error",
    "supabase:test": "bash scripts/sites-env.sh -- supabase test db"
  },
  "dependencies": {
    "@supabase/ssr": "0.12.3",
    "@supabase/supabase-js": "2.110.5",
    "drizzle-orm": "0.45.2",
    "lucide-react": "1.24.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.46.0",
    "@tailwindcss/postcss": "4.3.3",
    "@types/node": "26.1.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.4",
    "@vitejs/plugin-rsc": "0.5.29",
    "drizzle-kit": "0.31.10",
    "eslint": "10.7.0",
    "eslint-config-next": "16.2.11",
    "react-server-dom-webpack": "19.2.8",
    "supabase": "2.109.1",
    "tailwindcss": "4.3.3",
    "typescript": "7.0.2",
    "vinext": "0.2.1",
    "vite": "8.1.5",
    "wrangler": "4.113.0"
  },
  "type": "module",
  "displayName": "H&NTrip"
}
