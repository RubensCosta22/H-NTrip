# Public Supabase configuration. These values identify the project but are not privileged.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Legacy projects may use NEXT_PUBLIC_SUPABASE_ANON_KEY instead.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only configuration. Never prefix secrets with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Canonical URL for the current environment (local, staging or production).
APP_URL=http://localhost:3000

# Comma-separated administrator emails used only by a controlled bootstrap process.
BOOTSTRAP_ADMIN_EMAILS=
